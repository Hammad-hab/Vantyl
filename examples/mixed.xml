<?xml version="1.0"?>
<menu>
    <bg image="images/josh-nuttall-xl2piFfdzyA-unsplash.jpg" size="cover"/>
    <!-- Icon-theme name, resolved against the system icon theme -->
    <item name="Firefox" icon="firefox" exec="firefox"/>

    <!-- Real file on disk, loaded directly and scaled to fit -->
    <item name="Thunderbird" icon="/usr/share/icons/hicolor/48x48/apps/thunderbird.png" exec="thunderbird"/>

    <!-- No icon at all, falls back to the default item icon -->
    <item name="Mystery App" exec="mystery-app"/>

    <!-- Bad path, falls back to the default icon and prints a warning -->
    <item name="Broken Icon" icon="/no/such/file.png" exec="echo hello"/>

    <folder name="Custom Icons" icon="/usr/share/pixmaps/folder-custom.png">
        <item name="Home" icon="~/icons/home.png" exec="pcmanfm ~"/>
    </folder>
</menu>